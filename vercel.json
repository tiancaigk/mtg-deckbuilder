{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/supabase\\.js",
      "dest": "/supabase.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
